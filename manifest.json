{
  "manifest_version": 3,
  "name": "FramedShot",
  "version": "2.0",
  "description": "Turn plain screenshots into polished visuals with social-ready sizes, clean markup, and fast export or copy.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "commands": {
    "capture-selection": {
      "description": "Select an area on the page and open it in FramedShot"
    }
  },
  "icons": {
    "16": "assets/icons/framedshot-logo.png",
    "48": "assets/icons/framedshot-logo.png",
    "128": "assets/icons/framedshot-logo.png"
  },
  "action": {
    "default_title": "Frame this Shot",
    "default_icon": {
      "16": "assets/icons/framedshot-logo.png",
      "48": "assets/icons/framedshot-logo.png",
      "128": "assets/icons/framedshot-logo.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js"
  }
}
